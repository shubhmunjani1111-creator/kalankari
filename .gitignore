# Root Gitignore for Kalankari MERN Project

# Dependency directories
node_modules/
backend/node_modules/
frontend/node_modules/

# Local configuration files
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# Build outputs
dist/
backend/dist/
frontend/dist/
frontend/.next/
out/
build/

# IDE files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
logs/
*.log
