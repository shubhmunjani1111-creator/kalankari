# Kalankari Backend Environment Configuration Template

# Server Port
PORT=5000

# MongoDB Database Connection String
MONGO_URI=your_mongodb_connection_uri

# JWT Authentication Secret Key
JWT_SECRET=your_jwt_secret_key

# Razorpay Configuration (Add your actual credentials here)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Admin Credentials
ADMIN_PASSWORD=your_admin_dashboard_password

# Cloudinary Storage Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email configuration
EMAIL_PROVIDER=resend
EMAIL_API_KEY=your_resend_api_key
ADMIN_EMAIL=your_admin_notification_receiver_email
FROM_EMAIL=order@kalankari.com
FRONTEND_URL=https://kalankari.com
